# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://webhook:webhook@localhost:5432/webhookdb

# ── LLM Provider (choose one) ─────────────────────────────────────────────────
# Options: groq | gemini | anthropic
LLM_PROVIDER=groq

# Groq — FREE at https://console.groq.com (no credit card)
GROQ_API_KEY=gsk_...
# GROQ_MODEL=llama-3.3-70b-versatile   # default
# GROQ_MODEL=qwen-qwq-32b              # if you want Qwen specifically

# Google Gemini — FREE at https://aistudio.google.com
# LLM_PROVIDER=gemini
# GOOGLE_API_KEY=AIza...

# Anthropic Claude — paid
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
